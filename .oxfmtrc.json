{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "semi": true,
  "tabWidth": 2,
  "printWidth": 80,
  "singleQuote": true,
  "trailingComma": "es5",
  "bracketSpacing": true,
  "sortPackageJson": false,
  "sortImports": {
    "newlinesBetween": true,
    "internalPattern": ["~/**"],
    "groups": [
      ["value-builtin", "value-external"],
      "value-internal",
      ["value-parent", "value-sibling", "value-index"],
      "type-import",
      "unknown"
    ]
  },
  "sortTailwindcss": {
    "stylesheet": "src/styles/app.css",
    "functions": ["cn", "cva"]
  },
  "ignorePatterns": [
    "src/routeTree.gen.ts",
    "**/*.gen.ts",
    "pnpm-lock.yaml",
    "dist/**",
    ".netlify/**",
    ".agents/**"
  ]
}
